# ── NEXUS Game Launcher — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
# URL where this FastAPI backend is reachable (used in OAuth redirect_uri)
BACKEND_URL=http://localhost:8000

# URL of the GitHub Pages frontend (used to redirect back after OAuth)
FRONTEND_URL=https://Arnav1771.github.io/multi-platform-game-launcher

# Secret used to sign session tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-32-char-hex-string

# ── Steam ─────────────────────────────────────────────────────────────────────
# Free API key from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ── Epic Games ────────────────────────────────────────────────────────────────
# Register your app at https://dev.epicgames.com/portal
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=

# ── GOG ───────────────────────────────────────────────────────────────────────
# Request credentials from GOG developer program
GOG_CLIENT_ID=
GOG_CLIENT_SECRET=

# ── Xbox / Microsoft ──────────────────────────────────────────────────────────
# Register at https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
